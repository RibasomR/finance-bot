# Telegram bot token (get it from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Database (SQLite for development, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./finance.db
# DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/finance_bot

# PostgreSQL (for Docker)
POSTGRES_USER=finance_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=finance_bot

# Redis (optional, for rate limiting)
REDIS_URL=redis://:change_me_in_production@localhost:6379/0
REDIS_PASSWORD=change_me_in_production

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log

# Application
MAX_TRANSACTION_AMOUNT=10000000
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_PERIOD=60

# AI Provider (any OpenAI-compatible API: Groq, OpenAI, Ollama, etc.)
AI_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=your_api_key_here
AI_CHAT_MODEL=llama-3.3-70b-versatile
AI_WHISPER_MODEL=whisper-large-v3-turbo
AI_PROXY=